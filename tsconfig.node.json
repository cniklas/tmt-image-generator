{
	"extends": "@tsconfig/node24/tsconfig.json",
	"include": ["vite.config.*", "vitest.config.*", "cypress.config.*", "playwright.config.*", "eslint.config.*"],
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"types": ["node"],
		"composite": true,
		"noEmit": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo"
	}
}
